// Nirog Care Platform — shared clinical backend.
// Mirrors the domain contract in src/lib/domain/types.ts and the pitch's
// trust architecture: identity, scoped care relationships, consent, audit.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for the app.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) for migrations / db push, which can't run
  // through the pooler. On Supabase this is the "Direct"/"Session" string.
  directUrl = env("DIRECT_URL")
}

enum Sex {
  male
  female
  other
}

enum TriageLevel {
  emergency
  urgent
  routine
}

enum QueueState {
  waiting
  in_consult
  completed
  no_show
  scheduled
}

enum EncounterKind {
  new
  follow_up
  pediatrics
  chronic
  emergency
}

enum ConsultChannel {
  video
  audio
  chat
}

enum RelationshipRole {
  self
  child
  parent
  spouse
  dependent
}

/// The authenticated person who owns one or more patient profiles.
/// This is the patient-app user: signs in (phone OTP) against the SAME
/// Supabase Auth as doctors; `authUserId` maps auth.uid() → this Account.
model Account {
  id            String    @id @default(cuid())
  phone         String    @unique
  // Links the patient-app user to a Supabase Auth user (auth.users.id).
  authUserId    String?   @unique @db.Uuid
  // Expo push token so we can notify the patient when a doctor picks up.
  expoPushToken String?
  createdAt     DateTime  @default(now())
  patients      Patient[]
}

/// A verified clinician who signs in to the doctor portal.
model Doctor {
  id             String        @id @default(cuid())
  // Links this clinician profile to a Supabase Auth user (auth.users.id).
  // RLS maps auth.uid() → this Doctor row.
  authUserId     String?       @unique @db.Uuid
  fullName       String
  email          String        @unique
  passwordHash   String?       // legacy; Supabase Auth now owns credentials
  specialty      String
  registrationNo String        @unique
  languages      String[]
  clinicName     String
  mfaEnabled     Boolean       @default(true)
  avatarTone     String?
  // Onboarding / verification (Apollo-style, country-aware). The full payload
  // lives in `profile` JSON; a few fields are promoted to columns for the app.
  onboardingComplete Boolean   @default(false)
  country            String?
  profile            Json?
  // On-demand availability: doctors toggle "on call" and the portal beats a
  // heartbeat into lastSeenAt, so the patient queue matches only live doctors.
  onCall             Boolean   @default(false)
  lastSeenAt         DateTime?
  createdAt      DateTime      @default(now())
  queue          QueueEntry[]
  encounters     Encounter[]
  consents       ConsentGrant[]
  audits         AuditEvent[]
  prescriptions  Prescription[]
}

/// A partner pharmacy that fulfils prescriptions (the "Fulfil" step of the
/// care loop). Mirrors Doctor: signs up against the same Supabase Auth,
/// completes a country-aware verification wizard, then waits for approval.
model Pharmacy {
  id         String   @id @default(cuid())
  // Links this pharmacy to a Supabase Auth user (auth.users.id).
  authUserId String?  @unique @db.Uuid
  name       String
  email      String   @unique
  // Drug licence / board registration — the regulated identifier.
  licenseNo  String   @unique
  ownerName  String
  phone      String?
  city       String?
  district   String?
  state      String?
  country    String?
  services   String[]
  avatarTone String?
  // Verification lifecycle, same shape as Doctor.
  onboardingComplete Boolean  @default(false)
  verified           Boolean  @default(false)
  /// Full onboarding payload (country-aware fields + document paths).
  profile            Json?
  createdAt          DateTime @default(now())

  orders PharmacyOrder[]
}

/// A patient profile. An account is NOT a patient; relationships are explicit.
model Patient {
  id                    String           @id @default(cuid())
  account               Account          @relation(fields: [accountId], references: [id])
  accountId             String
  fullName              String
  sex                   Sex
  dateOfBirth           DateTime
  phoneMasked           String
  village               String
  district              String
  preferredLanguage     String
  abhaLinked            Boolean          @default(false)
  relationshipToAccount RelationshipRole
  allergies             String[]
  conditions            String[]
  currentMedications    String[]
  avatarTone            String?
  handovers             AriaHandover[]
  queueEntries          QueueEntry[]
  encounters            Encounter[]
  consents              ConsentGrant[]
  prescriptions         Prescription[]
}

/// ARIA (AI intake) structured, UNVERIFIED summary handed to a clinician.
model AriaHandover {
  id               String      @id @default(cuid())
  patient          Patient     @relation(fields: [patientId], references: [id])
  patientId        String
  createdAt        DateTime    @default(now())
  chiefComplaint   String
  narrative        String
  durationText     String
  symptoms         String[]
  redFlags         String[]
  vitals           Json?
  aiConfidence     Float
  suggestedTriage  TriageLevel
  language         String
  verifiedByDoctor Boolean     @default(false)
  queueEntry       QueueEntry?
}

/// A live position in the consult queue. When a patient requests an on-demand
/// consult, doctorId is NULL (unassigned pool); an on-call doctor claims it
/// atomically (sets doctorId + state=in_consult). Scheduled/seeded rows keep a
/// doctor from the start.
model QueueEntry {
  id                String         @id @default(cuid())
  patient           Patient        @relation(fields: [patientId], references: [id])
  patientId         String
  doctor            Doctor?        @relation(fields: [doctorId], references: [id])
  doctorId          String?
  kind              EncounterKind
  triage            TriageLevel
  state             QueueState     @default(scheduled)
  checkedInAt       DateTime
  scheduledFor      DateTime
  channel           ConsultChannel
  reason            String
  connectionQuality String         @default("good")
  handover          AriaHandover?  @relation(fields: [handoverId], references: [id])
  handoverId        String?        @unique
}

/// A completed or in-progress clinical encounter (the care plan).
model Encounter {
  id             String         @id @default(cuid())
  patient        Patient        @relation(fields: [patientId], references: [id])
  patientId      String
  doctor         Doctor         @relation(fields: [doctorId], references: [id])
  doctorId       String
  startedAt      DateTime       @default(now())
  endedAt        DateTime?
  channel        ConsultChannel
  chiefComplaint String
  assessment     String
  clinicalNotes  String
  prescriptions  Json           @default("[]")
  labRequests    Json           @default("[]")
  followUp       Json?
  ariaAccepted   Boolean        @default(false)
  prescription   Prescription?
}

/// Purpose-specific, revocable consent that gates record access.
model ConsentGrant {
  id        String   @id @default(cuid())
  patient   Patient  @relation(fields: [patientId], references: [id])
  patientId String
  doctor    Doctor   @relation(fields: [grantedTo], references: [id])
  grantedTo String
  purpose   String
  scope     String[]
  grantedAt DateTime @default(now())
  expiresAt DateTime
  active    Boolean  @default(true)
}

/// Immutable audit trail: who / what / why.
model AuditEvent {
  id        String   @id @default(cuid())
  doctor    Doctor?  @relation(fields: [actorId], references: [id])
  actorId   String?
  actorName String
  action    String
  target    String
  reason    String?
  at        DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Fulfilment — the "Fulfil" step of the care loop.
//
// A filed Encounter mints a Prescription. The Prescription is routed to the
// patient's district as an unassigned PharmacyOrder (pharmacyId = NULL) — the
// same pool-and-claim shape as the on-demand doctor queue. Any *verified*
// pharmacy in that district can atomically claim it, then walk it through
// fulfilment. Every transition appends an immutable OrderEvent.
// ─────────────────────────────────────────────────────────────────────────────

/// WHO ATC/DDD drug catalogue — the global classification of drug substances.
/// Seeded from the WHO Collaborating Centre ATC index (5 levels: anatomical →
/// therapeutic → pharmacological → chemical → substance).
model Drug {
  id      String @id @default(cuid())
  /// WHO ATC substance code, e.g. C08CA01 (amlodipine).
  atcCode String @unique
  /// INN generic name.
  name    String

  // Denormalised hierarchy — keeps catalogue search and faceting a single scan.
  anatomicalCode      String
  anatomicalName      String
  therapeuticCode     String
  therapeuticName     String
  pharmacologicalCode String
  pharmacologicalName String
  chemicalCode        String
  chemicalName        String

  /// WHO Defined Daily Dose (the assumed average maintenance dose).
  ddd       Float?
  dddUom    String?
  /// Route of administration the DDD applies to (O, P, N, R, SL, TD, …).
  route     String?
  /// Lowercased name + ATC + class text, for trigram search.
  searchText String

  items PrescriptionItem[]

  @@index([anatomicalCode])
  @@index([name])
}

enum PrescriptionStatus {
  issued
  routed
  fulfilled
  cancelled
}

enum OrderStatus {
  routed
  accepted
  preparing
  ready
  dispatched
  delivered
  rejected
  cancelled
}

enum DeliveryMode {
  pickup
  delivery
}

/// A digitally issued prescription — one per encounter.
model Prescription {
  id          String             @id @default(cuid())
  encounter   Encounter          @relation(fields: [encounterId], references: [id])
  encounterId String             @unique
  patient     Patient            @relation(fields: [patientId], references: [id])
  patientId   String
  doctor      Doctor             @relation(fields: [doctorId], references: [id])
  doctorId    String
  issuedAt    DateTime           @default(now())
  status      PrescriptionStatus @default(issued)
  /// Free-text dispensing note for the pharmacist.
  notes       String?
  /// Snapshot of the prescriber at issue time — a prescription must stay
  /// readable and attributable even if the doctor profile later changes.
  doctorName  String
  doctorRegNo String

  items PrescriptionItem[]
  order PharmacyOrder?

  @@index([patientId])
  @@index([doctorId])
}

/// One prescribed line. `drug` links the WHO catalogue entry; the name/strength
/// are ALSO snapshotted so the line stays legible if the catalogue changes.
model PrescriptionItem {
  id             String       @id @default(cuid())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  prescriptionId String
  drug           Drug?        @relation(fields: [drugId], references: [id])
  drugId         String?
  /// Snapshot — what the doctor actually wrote.
  drugName       String
  atcCode        String?
  strength       String?
  form           String?
  dose           String?
  frequency      String?
  durationDays   Int?
  quantity       Int?
  instructions   String?
  /// May the pharmacy dispense an equivalent generic?
  substitutionAllowed Boolean @default(true)

  @@index([prescriptionId])
}

/// A prescription routed to a district for fulfilment. pharmacyId is NULL while
/// it sits in the pool; claiming it assigns the pharmacy atomically.
model PharmacyOrder {
  id             String       @id @default(cuid())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  prescriptionId String       @unique
  pharmacy       Pharmacy?    @relation(fields: [pharmacyId], references: [id])
  pharmacyId     String?

  // Routing key — the pool is scoped by geography, not by patient identity.
  district String?
  state    String?
  country  String?

  status       OrderStatus  @default(routed)
  deliveryMode DeliveryMode @default(delivery)

  // Delivery snapshot. Deliberately NOT a join to Patient: a pharmacy gets the
  // minimum needed to dispense and deliver, and no access to the clinical
  // record. Widening this would need a new consent scope, not a new join.
  patientName    String
  patientPhone   String?
  patientVillage String?
  patientDistrict String?

  routedAt        DateTime  @default(now())
  acceptedAt      DateTime?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  rejectionReason String?
  /// Settlement amount once priced by the pharmacy (minor units of country ccy).
  totalAmount     Int?

  events OrderEvent[]

  @@index([pharmacyId, status])
  @@index([district, status])
}

/// Append-only fulfilment trail for one order.
model OrderEvent {
  id      String      @id @default(cuid())
  order   PharmacyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String
  status  OrderStatus
  note    String?
  actor   String
  at      DateTime    @default(now())

  @@index([orderId])
}
